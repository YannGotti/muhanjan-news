APP_NAME=MuhanjanNews API
APP_ENV=production
DEBUG=false
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql+psycopg://muhanjannews:strong_password_here@localhost:5432/muhanjannews

JWT_SECRET_KEY=change_me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

ADMIN_USERNAME=admin

# Временный fallback. Лучше использовать ADMIN_PASSWORD_HASH.
ADMIN_PASSWORD=change_me

# Рекомендуемый вариант для продакшена.
# Сгенерируй через: python scripts/generate_admin_password_hash.py "new_password"
ADMIN_PASSWORD_HASH=

UPLOAD_DIR=../../storage/uploads
BASE_PUBLIC_API_URL=http://127.0.0.1:8002
BASE_PUBLIC_WEB_URL=http://127.0.0.1:5174
CORS_ALLOW_ORIGINS=http://localhost:5174

MAX_ATTACHMENT_FILE_SIZE_BYTES=20971520

TELEGRAM_BOT_TOKEN=
TELEGRAM_PARSE_MODE=HTML
TELEGRAM_REQUEST_TIMEOUT_SECONDS=5
