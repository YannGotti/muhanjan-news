APP_NAME=MuhanjanNews API
APP_ENV=production
DEBUG=false
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql+psycopg://muhanjannews:strong_password_here@localhost:5432/muhanjannews
JWT_SECRET_KEY=change_me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
ADMIN_PASSWORD_HASH=

UPLOAD_DIR=../../storage/uploads
BASE_PUBLIC_API_URL=http://127.0.0.1:8002
BASE_PUBLIC_WEB_URL=http://127.0.0.1:5174
CORS_ALLOW_ORIGINS=http://localhost:5174

TELEGRAM_BOT_TOKEN=
TELEGRAM_PARSE_MODE=HTML
TELEGRAM_REQUEST_TIMEOUT_SECONDS=10
TELEGRAM_PROXY_URL=socks5://127.0.0.1:2080

REDIS_URL=redis://localhost:6379/0
NOTIFICATION_QUEUE_KEY=mn:queue:notifications
NOTIFICATION_RETRY_QUEUE_KEY=mn:queue:notifications:retry
REDIS_SOCKET_TIMEOUT_SECONDS=2
REDIS_BLOCKING_SOCKET_TIMEOUT_SECONDS=15
NOTIFICATION_WORKER_BLOCK_TIMEOUT_SECONDS=5

MAX_ATTACHMENT_FILE_SIZE_BYTES=20971520
AUTH_LOGIN_RATE_LIMIT_ATTEMPTS=5
AUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
